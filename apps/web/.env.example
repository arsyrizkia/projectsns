# Supabase (client-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# 32-byte base64 key for AES-256-GCM token encryption (generate: openssl rand -base64 32)
TOKEN_ENC_KEY=

# HMAC secret for OAuth state signing (generate: openssl rand -hex 32)
OAUTH_STATE_SECRET=

# Public origin of this deployment, used for OAuth redirect URIs
APP_ORIGIN=http://localhost:3000

# Platform developer app credentials (per-deployment, BYO)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
